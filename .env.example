# Copy to .env (local) and set the same vars in Vercel → Project → Settings → Environment Variables.

# Stripe — use test keys (sk_test_/whsec_ from a test-mode webhook) until one
# full order has gone through, then swap to live.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Printful — Settings → Stores → API (or Developers). Needs a payment method
# on file at Printful → Billing or orders won't fulfil.
PRINTFUL_API_TOKEN=xxx
# Only if your token covers more than one store:
PRINTFUL_STORE_ID=
# "true" auto-submits orders for fulfilment; leave unset to hold them as
# drafts you approve by hand (recommended while testing).
PRINTFUL_CONFIRM_ORDERS=

# Custom order-confirmation email (optional). resend.com -> API Keys.
# Without it, buyers still get Stripe's receipt; this adds the XP-styled
# order email with items and sizes.
RESEND_API_KEY=
# Sender. Until the 10to2.net domain is verified in Resend (Domains -> Add
# Domain -> add their DNS records), leave unset: the resend.dev fallback
# only delivers to your own Resend account email (fine for testing).
EMAIL_FROM="10to2 <orders@10to2.net>"
